{
  "expo": {
    "name": "GauchoCowork",
    "slug": "gaucho-cowork",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "gauchocowork",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gaucho.cowork",
      "infoPlist": {
        "NSCameraUsageDescription": "Necesitamos acceso a la cámara para escanear códigos QR del servidor"
      }
    },
    "android": {
      "package": "com.gaucho.cowork"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": ["expo-router"]
  }
}
